# ─────────────────────────────────────────────────
# AgentFlow – Environment Variables
# Copy this file to .env and configure the values
# ─────────────────────────────────────────────────

# ── Database ──────────────────────────────────────
# For local dev without PostgreSQL, set USE_SQLITE=true
USE_SQLITE=true

# For PostgreSQL / AlloyDB (production):
# USE_SQLITE=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=agentflow
# DB_PASSWORD=changeme
# DB_NAME=agentflow

# ── Google Cloud / Vertex AI ──────────────────────
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_REGION=us-central1
GEMINI_MODEL=gemini-2.0-flash-exp

# ── CORS (comma-separated origins) ───────────────
CORS_ORIGINS=["*"]
